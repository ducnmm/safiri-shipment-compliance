{
  "name": "safiri-shipment-compliance",
  "version": "1.0.0",
  "description": "Shipment Compliance Automation Mini-System — ingest documents, validate shipments against compliance rules, produce a readiness report, and keep an audit trail.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "start:prod": "prisma migrate deploy && tsx prisma/seed.ts && tsx src/server.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/client": "^6.2.1",
    "fastify": "^5.2.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "openapi-types": "^12.1.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
